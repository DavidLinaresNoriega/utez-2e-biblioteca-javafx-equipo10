<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox prefHeight="800.0" prefWidth="850.0" spacing="10.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.integradora.controllers.MainController">
    <children>
        <Label text="Catálogo de Libros - Biblioteca Escolar" style="-fx-font-size: 16px; -fx-font-weight: bold;">
            <VBox.margin>
                <Insets left="10.0" top="10.0" />
            </VBox.margin></Label>

        <SplitPane dividerPositions="0.7" VBox.vgrow="ALWAYS">
            <items>
                <TableView fx:id="tableBooks" >
                    <columns>
                        <TableColumn fx:id="colIsbn" prefWidth="100.0" text="ISBN/ID" />
                        <TableColumn fx:id="colTitle" prefWidth="150.0" text="Título" />
                        <TableColumn fx:id="colAuthor" prefWidth="120.0" text="Autor" />
                        <TableColumn fx:id="colYear" prefWidth="60.0" text="Año" />
                        <TableColumn fx:id="colGenre" prefWidth="100.0" text="Género" />
                        <TableColumn fx:id="colDisponible" text="Disponible" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>

                <ScrollPane fitToWidth="true" >
                    <content>
                        <VBox spacing="8.0" >
                            <children>
                                <Label text="DETALLES"  />
                                <Separator />

                                <Label text="ISBN"  />
                                <Label fx:id="lblDetalleIsbn" text="---" wrapText="true" />

                                <Label text="TÍTULO"  />
                                <Label fx:id="lblDetalleTitulo" text="---" wrapText="true"  />

                                <Label text="AUTOR"  />
                                <Label fx:id="lblDetalleAutor" text="---" wrapText="true" />

                                <Label text="AÑO"  />
                                <Label fx:id="lblDetalleYear" text="---" />

                                <Label text="GÉNERO"  />
                                <Label fx:id="lblDetalleGenero" text="---" />

                                <Label text="DISPONIBILIDAD"  />
                                <Label fx:id="lblDetalleDisponible" text="---" />
                            </children>
                        </VBox>
                    </content>
                </ScrollPane>
            </items>
        </SplitPane>

        <HBox spacing="10.0" alignment="CENTER_LEFT">
            <children>
                <Button fx:id="btnNew" onAction="#nuevoLibro" text="Nuevo" />
                <Button fx:id="btnEdit" onAction="#nuevoLibro" text="Editar" />
                <Button fx:id="btnDelete" onAction="#onRemove" text="Eliminar" />
                <Region HBox.hgrow="ALWAYS" />
                <Button fx:id="btnExport" text="Exportar reporte" onAction="#exportar"/>
            </children>
            <VBox.margin>
                <Insets left="10.0" right="10.0" bottom="5.0" />
            </VBox.margin>
        </HBox>

        <Label fx:id="lblMsg" wrapText="true" minHeight="25.0" style="-fx-padding: 0 10 5 10;" />
    </children>
</VBox>
