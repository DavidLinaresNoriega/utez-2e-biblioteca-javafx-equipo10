<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox maxHeight="600.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.integradora.controllers.FormController">
    <children>
        <VBox prefHeight="302.0" prefWidth="600.0">
            <children>
                <Label text="Registro / Edición de Libro" />
                <GridPane prefHeight="200.0" prefWidth="600.0">
                    <columnConstraints>
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                    </columnConstraints>
                    <rowConstraints>
                        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                        <RowConstraints />
                    </rowConstraints>
                    <children>
                        <Label text="ISBN/ID:" />
                        <Label text="Título:" GridPane.rowIndex="1" />
                        <Label text="Autor:" GridPane.rowIndex="2" />
                        <Label text="Año:" GridPane.rowIndex="3" />
                        <Label text="Género:" GridPane.rowIndex="4" />
                        <Label text="Disponible:" GridPane.rowIndex="5" />
                        <TextField fx:id="txtIsbn" GridPane.columnIndex="1" />
                        <TextField fx:id="txtTitle" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                        <TextField fx:id="txtAutor" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                        <TextField fx:id="txtYear" GridPane.columnIndex="1" GridPane.rowIndex="3" />
                        <ComboBox fx:id="cbGenero" prefWidth="150.0" GridPane.columnIndex="1" GridPane.rowIndex="4" />
                        <ComboBox fx:id="cbDisponible" prefWidth="150.0" GridPane.columnIndex="1" GridPane.rowIndex="5" />
                    </children>
                </GridPane>
            </children>
        </VBox>
        <HBox prefHeight="50.0" prefWidth="600.0" spacing="20.0">
            <children>
                <Button fx:id="btnSave" mnemonicParsing="false" onAction="#onAdd" text="Guardar" />
                <Button fx:id="btnCancel" mnemonicParsing="false" onAction="#cancelar" text="Cancelar" />
            </children>
        </HBox>
        <Label fx:id="lblMsg" minHeight="40.0" maxHeight="400.0" text=" " wrapText="true" />
    </children>
</VBox>
